# proxy settings and target root for debootstrap
export http_proxy=http://192.168.178.48:3142
export https_proxy=http://192.168.178.48:3142

# ln ../../config.env config.env -s
export target_root=/tmp/debootstrap

export INSTALL_STEPS=desktop # base,bootloader,desktop

export INSTALL_BOOTLOADER=grub-pc # none, grub-efi, grub-pc
export INSTALL_CHROOT_ONLY=false # true if u what to use debian on phone or other chroot app
export INSTALL_CLI_TOOLS=true # lsbk, htop, screen, ... "template/debootstrap/base/03-packages-cli-tools.txt"
export INSTALL_DESKTOP_ENVIRONMENT=none # none, mate
export INSTALL_DESKTOP_TOOLS=true # mate-system-monitor, firefox, vlc, audacity, ...
export INSTALL_KERNEL=true # initramfs, kernel, ... (required for bootloader)
export INSTALL_NETWORK_TOOLS=true # only false if u are in chroot or small system. systemd-networkd, ...

# export INSTALL_FIRMWARE=true # TODO xD
export BOOTLOADER_BIOS_DEVICE=/dev/sdg # only required for BIOS boot (grub-pc)
export BOOTLOADER_BIOS_PARTITION=none # not required btrfs, maybe required for other filesystems, like encrypted ones
export BOOTLOADER_EFI_PARTITION=/dev/sdg3 # only required for UEFI boot (GRUB x86_64-efi)
export FORMART_EFI_PARTITION=false # formatting the EFI partition
export FSTAB_BOOT_BIOS_DEVICE_MOUNTPOINT=/boot # if efi (/boot/efi), if bios (/boot)
export FSTAB_BOOT_BIOS_DEVICE=none # UUID of the boot partition
export FSTAB_BOOT_EFI_DEVICE_MOUNTPOINT=/boot/efi # if efi (/boot/efi), if bios (/boot)
export FSTAB_BOOT_EFI_DEVICE=UUID=B01D-8789 # UUID of the boot partition
export FSTAB_BUILD=true # build fstab with the above settings, set false if you want to use a custom fstab
export FSTAB_ROOT_DEVICE_TYPE=btrfs # filesystem type (btrfs)
export FSTAB_ROOT_DEVICE=UUID=17fc8245-a2bc-46d4-aa81-9a43f446ad84 # UUID of the root partition
export FSTAB_ROOT_MOUNT_OPTIONS="noatime,nodiratime,compress=zstd:5,subvol=linux,space_cache=v2" # mount options for the root partition (ssd -> zstd:3, hdd zstd:5)
export FSTAB_SWAP_DEVICE=none # UUID of the swap partition, none if no swap partition is used
export MOUNT_REAL_BOOT=true # needed for grub-install, set false if already mounted by host system
export MOUNT_REAL_ROOT=true # needed for grub-install, set false if already mounted by host system

# for chroot install.sh
export NEW_HOSTNAME=LFF-ExoneMiniI5G3-2013
export NEW_ROOT_PASSWD=true # true if u want to set an root password
export NEW_USER_AUTOLOGIN=false # true if u want to autologin the user (only for desktop install)
export NEW_USER_GROUPS=tty,cdrom,floppy,sudo,audio,dip,video,plugdev,users,render # none if u dont want extra groups
export NEW_USER=lff # none, if u dont want an user (not recommend!)

# just leave me alive haha i m the log function xD
log() {
	local msg="$1"
	local caller_file="${BASH_SOURCE[1]:-$0}"
	echo -e "$msg"
	echo "[$(date +'%Y-%m-%d %H:%M:%S')][$caller_file] $msg" >> /debootstrap/install.log
}

apt_install() {
	packagesListFile="$1"
	packages=$(grep -vE '^\s*#|^\s*$' "$packagesListFile" | xargs)
	log "Installing packages: $packages"
	time apt install --no-install-recommends $packages -y
	if [ $? -ne 0 ]; then
		log "Error installing packages!"
		sleep 60
		exit 1
	fi
}
contains_package() {
    local file="$1"
    local search="$2"
    grep -vE '^\s*#|^\s*$' "$file" | grep -qxF "$search"
}
