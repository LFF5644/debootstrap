# proxy settings and target root for debootstrap
export http_proxy=http://192.168.178.48:3142
export https_proxy=http://192.168.178.48:3142

# ln ../../config.env config.env -s
export target_root=/tmp/debootstrap

export INSTALL_STEPS=base

export INSTALL_CLI_TOOLS=true
export INSTALL_NETWORK_TOOLS=true
export INSTALL_CHROOT_ONLY=false
export INSTALL_DESKTOP_ENVIRONMENT=mate # none, mate
export INSTALL_DESKTOP_TOOLS=true
export INSTALL_BOOTLOADER=none # none, grub-efi, grub-pc
export INSTALL_KERNEL=true
# export INSTALL_FIRMWARE=true # TODO xD
export INSTALL_BOOTLOADER_DEVICE=/dev/sdx # only required for BIOS boot (GRUB i386)
export INSTALL_BOOTLOADER_DEVICE_INSTALL=/dev/sdx # only required for BIOS boot (GRUB i386)
export INSTALL_BOOTLOADER_PARTITION_EFI=/boot/efi # only required for UEFI boot (GRUB x86_64-efi)

# for chroot install.sh
export NEW_USER=lff
export NEW_USER_COMMENT=LFF5644
export NEW_GROUPS=lff,tty,cdrom,floppy,sudo,audio,dip,video,plugdev,users,render,netdev
export NEW_HOSTNAME=LFF-ExoneMiniI5G3-2013

# just leave me alive haha i m the log function xD
log() {
	echo "$1"
	echo "[$(date +'%Y-%m-%d %H:%M:%S')][$1] $1" >> /debootstrap/install.log
}

apt_install(packagesListFile) {
	packages=$(grep -vE '^\s*#|^\s*$' "$packagesListFile" | xargs)
	log "Installing packages: $packages"
	time apt install --no-install-recommends $packages -y
	if [ $? -ne 0 ]; then
		log "Error installing packages!"
		sleep 60
		exit 1
	fi
}
