# proxy settings and target root for debootstrap
export http_proxy=http://192.168.178.48:3142
export https_proxy=http://192.168.178.48:3142

# ln ../../config.env config.env -s
export target_root=/tmp/debootstrap

export INSTALL_STEPS=base

export INSTALL_CLI_TOOLS=true
export INSTALL_NETWORK_TOOLS=true
export INSTALL_CHROOT_ONLY=false
export INSTALL_DESKTOP_ENVIRONMENT=mate # none, mate
export INSTALL_DESKTOP_TOOLS=true
export INSTALL_BOOTLOADER=none # none, grub-efi, grub-pc
export INSTALL_KERNEL=true
# export INSTALL_FIRMWARE=true # TODO xD
export FORMART_EFI_PARTITION=false # formatting the EFI partition
export BOOTLOADER_BIOS_DEVICE=/dev/sdx # only required for BIOS boot (GRUB i386)
export BOOTLOADER_EFI_PARTITION=/dev/sdxN # only required for UEFI boot (GRUB x86_64-efi)

export FSTAB_ROOT_DEVICE=UUID=17fc8245-a2bc-46d4-aa81-9a43f446ad84 # UUID of the root partition
export FSTAB_ROOT_DEVICE_TYPE=btrfs # filesystem type (btrfs)
export FSTAB_ROOT_MOUNT_OPTIONS="noatime,nodiratime,compress=zstd:5,subvol=linux,space_cache=v2" # mount options for the root partition (ssd -> zstd:3, hdd zstd:5)
export MOUNT_REAL_ROOT=true # needed for grub-install, set false if already mounted by host system
export MOUNT_REAL_BOOT=true # needed for grub-install, set false if already mounted by host system

export FSTAB_SWAP_DEVICE=none # UUID of the swap partition, none if no swap partition is used
export FSTAB_BOOT_DEVICE=UUID=B01D-8789 # UUID of the boot partition

# for chroot install.sh
export NEW_USER=lff
export NEW_USER_COMMENT=LFF5644
export NEW_GROUPS=lff,tty,cdrom,floppy,sudo,audio,dip,video,plugdev,users,render,netdev
export NEW_HOSTNAME=LFF-ExoneMiniI5G3-2013

# just leave me alive haha i m the log function xD
log() {
	echo "$1"
	echo "[$(date +'%Y-%m-%d %H:%M:%S')][$1] $1" >> /debootstrap/install.log
}

apt_install() {
	packagesListFile="$1"
	packages=$(grep -vE '^\s*#|^\s*$' "$packagesListFile" | xargs)
	log "Installing packages: $packages"
	time apt install --no-install-recommends $packages -y
	if [ $? -ne 0 ]; then
		log "Error installing packages!"
		sleep 60
		exit 1
	fi
}
